{
  "name": "jukebox",
  "version": "1.4.0",
  "description": "Bar jukebox — patron song request queue via Spotify",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "acme-client": "^5.4.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "nodemonConfig": {
    "ignore": [
      "history.json",
      "queue.json",
      "requestQueue.json",
      "playbackState.json",
      "unban-requests.json",
      "config.json",
      "*.pem",
      "node_modules"
    ]
  }
}
